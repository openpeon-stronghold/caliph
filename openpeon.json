{
  "cesp_version": "1.0",
  "name": "stronghold-caliph",
  "display_name": "The Caliph (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/ca_add_player_01.wav", "label": "Infidel!" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/ca_willattack_01.wav", "label": "Yes!" },
        { "file": "sounds/ca_sent_01.wav", "label": "I have sent your goods" },
        { "file": "sounds/ca_siege_01.wav", "label": "Watch and learn" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/ca_vict_01.wav", "label": "You are weak, infidel" },
        { "file": "sounds/ca_boast_01.wav", "label": "Dispose of all foes" },
        { "file": "sounds/ca_vict_04.wav", "label": "They all fall before me" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/ca_anger_01.wav", "label": "You test my patience" },
        { "file": "sounds/ca_anger_02.wav", "label": "You dare invade my lands" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/ca_help_01.wav", "label": "Send your fastest man" },
        { "file": "sounds/ca_req_01.wav", "label": "I need goods" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/ca_notsent_01.wav", "label": "You ask the impossible" },
        { "file": "sounds/ca_nohelp_02.wav", "label": "Will not waste my men" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/ca_noattack_01.wav", "label": "Do you take me for a fool" },
        { "file": "sounds/ca_kick_player_01.wav", "label": "Infidel" }
      ]
    }
  }
}
